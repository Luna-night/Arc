{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Arcaea",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#constants" },
    { "include": "#numbers" },
    { "include": "#operators" },
    { "include": "#functions" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.arcaea",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.arcaea",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.arcaea",
          "match": "\\\\."
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.arcaea",
          "match": "\\b(if|else|while|return|use)\\b"
        },
        {
          "name": "keyword.other.arcaea",
          "match": "\\b(let|print|bridge|func|system|package|service)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.arcaea",
          "match": "\\b(Int|Float|String)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.arcaea",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.arcaea",
          "match": "\\b-?[0-9]+\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.arcaea",
          "match": "\\b-?[0-9]+\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arcaea",
          "match": "(==|!=|<=|>=|->|[+\\-*/=<>])"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.arcaea",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()"
        }
      ]
    }
  },
  "scopeName": "source.arcaea"
}
